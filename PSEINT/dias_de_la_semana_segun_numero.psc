Proceso dias_de_la_semana_segun_numero
	// escribir un algoritmo que de los dias de la semana
	Definir n Como Entero;
	Escribir 'Dar un numero ';
	Leer n;
	Segun n  Hacer
		1:
			Escribir 'LUNES';
		2:
			Escribir 'MARTES';
		3:
			Escribir 'MIERCOLES';
		4:
			Escribir 'JUEVES';
		5:
			Escribir 'VIERNES';
		6:
			Escribir 'SABADO';
		7:
			Escribir 'DOMINGO';
		De Otro Modo:
			Escribir 'ERROR';
	FinSegun
FinProceso
