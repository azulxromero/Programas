Proceso vocal_o_consonante
	definir l como caracter;
	Escribir "da una letra   ";
	Leer l;
	Si l="a" Entonces
		Escribir "Es vocal ";
	SiNo
		Si l="e" Entonces
			Escribir "Es vocal ";
		SiNo
			Si l="i" Entonces
				Escribir "Es vocal";
			SiNo
				Si l="o" Entonces
					Escribir "Es vocal ";
				SiNo
					Si l="u" Entonces
						Escribir "Es vocal ";
					SiNo
						Escribir "Es consonante ";
					Fin Si
				Fin Si
			Fin Si
		Fin Si
	Fin Si
	
FinProceso
